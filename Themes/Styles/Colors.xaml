<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="WhiteColor">#FFFFFF</Color>
    <Color x:Key="TransparentColor">#00FFFFFF</Color>

    <Color x:Key="LightGrayColor">#EEEEEE</Color>
    <Color x:Key="MediumGrayColor">#B0B0B0</Color>
    <Color x:Key="DarkGrayColor">#666666</Color>
    <Color x:Key="TextColor">#333333</Color>

    <Color x:Key="ListHoverColor">#DDDDDD</Color>

    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource MediumGrayColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="GrayTextBrush" Color="{StaticResource DarkGrayColor}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="{StaticResource TransparentColor}"/>
    <SolidColorBrush x:Key="ListHoverBackgroundBrush" Color="{StaticResource ListHoverColor}"/>

    <Color x:Key="PrimaryColor">#007BFF</Color>
    <Color x:Key="PrimaryDarkerColor">#0069D9</Color>

    <Color x:Key="SecondaryColor">#ADB5BD</Color>
    <Color x:Key="SecondaryDarkerColor">#6C757D</Color>

    <Color x:Key="DangerColor">#DC3545</Color>
    <Color x:Key="DangerDarkerColor">#C82333</Color>
    <Color x:Key="DangerLightColor">#FFF5F5</Color>

    <Color x:Key="WarningColor">#FFC107</Color>
    <Color x:Key="WarningDarkerColor">#E0A800</Color>

    <Color x:Key="SuccessColor">#28A745</Color>
    <Color x:Key="SuccessDarkerColor">#218838</Color>

    <Color x:Key="FolderIconColor">#FFC107</Color>
    <Color x:Key="TreeIconColor">#388E3C</Color>

    <Color x:Key="ButtonTextColor">#FFFFFF</Color>

    <Color x:Key="IconButtonHoverColor">#E0E0E0</Color>
    <Color x:Key="IconButtonPressedColor">#C0C0C0</Color>
    <Color x:Key="ListActionIconHoverColor">#ADADAD</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkerBrush" Color="{StaticResource PrimaryDarkerColor}"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SecondaryDarkerBrush" Color="{StaticResource SecondaryDarkerColor}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerDarkerBrush" Color="{StaticResource DangerDarkerColor}"/>
    <SolidColorBrush x:Key="DangerLightBackgroundBrush" Color="{StaticResource DangerLightColor}"/>

    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningDarkerBrush" Color="{StaticResource WarningDarkerColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessDarkerBrush" Color="{StaticResource SuccessDarkerColor}"/>

    <SolidColorBrush x:Key="FolderIconBrush" Color="{StaticResource FolderIconColor}"/>
    <SolidColorBrush x:Key="TreeIconBrush" Color="{StaticResource TreeIconColor}"/>

    <SolidColorBrush x:Key="ButtonTextBrush" Color="{StaticResource ButtonTextColor}"/>

    <SolidColorBrush x:Key="IconButtonHoverBrush" Color="{StaticResource IconButtonHoverColor}"/>
    <SolidColorBrush x:Key="IconButtonPressedBrush" Color="{StaticResource IconButtonPressedColor}"/>
    <SolidColorBrush x:Key="ListActionIconHoverBrush" Color="{StaticResource ListActionIconHoverColor}"/>

    <Color x:Key="ComboBoxItemHighlightColor">#E6F2FF</Color>
    <SolidColorBrush x:Key="ComboBoxItemHighlightBrush" Color="{StaticResource ComboBoxItemHighlightColor}"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="{StaticResource PrimaryColor}"/>

    <Color x:Key="TabHoverColor">#D0D0D0</Color>
    <SolidColorBrush x:Key="TabHoverBrush" Color="{StaticResource TabHoverColor}"/>
    <SolidColorBrush x:Key="TabInactiveBackgroundBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="{StaticResource WhiteColor}"/>

    <Color x:Key="BadgeBackgroundColor">#F8F9FA</Color>
    <Color x:Key="BadgeHoverColor">#E9ECEF</Color>
    <Color x:Key="BadgePressedColor">#DEE2E6</Color>
    <Color x:Key="BadgeInactiveColor">#E0E0E0</Color>

    <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="{StaticResource BadgeBackgroundColor}"/>
    <SolidColorBrush x:Key="BadgeHoverBackgroundBrush" Color="{StaticResource BadgeHoverColor}"/>
    <SolidColorBrush x:Key="BadgePressedBackgroundBrush" Color="{StaticResource BadgePressedColor}"/>
    <SolidColorBrush x:Key="BadgeInactiveBackgroundBrush" Color="{StaticResource BadgeInactiveColor}"/>

</ResourceDictionary>