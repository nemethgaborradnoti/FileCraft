<Window x:Class="FileCraft.Views.Shared.ViewContentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FileCraft.ViewModels.Shared"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="500" Width="600"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <TextBox Grid.Row="1"
                 Text="{Binding Content, Mode=OneWay}"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 AcceptsReturn="True"
                 Style="{StaticResource ModernTextBoxStyle}"
                 Padding="5"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Copy to Clipboard"
                    Command="{Binding CopyCommand}"
                    Margin="0,0,10,0"
                    MinWidth="120"/>

            <Button Content="{DynamicResource Common_CloseButton}"
                    Command="{Binding CloseCommand}"
                    IsDefault="True"
                    IsCancel="True"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>