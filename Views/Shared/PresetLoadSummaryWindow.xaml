<Window x:Class="FileCraft.Views.Shared.PresetLoadSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FileCraft.ViewModels.Shared"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="500" Width="600"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Title}" Margin="0,0,0,10"/>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource PresetSummary_Total}"/>
                <TextBlock Grid.Column="1" Text="{Binding Result.TotalPaths}" FontWeight="Bold"/>
            </Grid>
            <Separator Margin="0,5"/>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource PresetSummary_Loaded}" Foreground="{StaticResource SuccessBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding Result.SuccessfullyLoaded}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
            </Grid>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource PresetSummary_Changed}" Margin="10,0,0,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Result.Changed}"/>
            </Grid>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource PresetSummary_Unchanged}" Margin="10,0,0,0" Foreground="{StaticResource GrayTextBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding Result.Unchanged}" Foreground="{StaticResource GrayTextBrush}"/>
            </Grid>

            <Separator Margin="0,5"/>

            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource PresetSummary_NotFound}" Foreground="{StaticResource DangerBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding Result.NotFoundPaths.Count}" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1" Visibility="{Binding HasNotFoundPaths, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Content="{Binding ToggleNotFoundButtonText}" 
                    Command="{Binding ToggleNotFoundCommand}"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,0,5"
                    HorizontalAlignment="Left"/>

            <TextBox Grid.Row="1"
                     Text="{Binding NotFoundPathsText, Mode=OneWay}"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Visibility="{Binding IsNotFoundVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                     Margin="0,0,0,10"
                     FontFamily="Consolas"
                     FontSize="12"
                     Style="{StaticResource ModernTextBoxStyle}"/>
        </Grid>

        <Button Grid.Row="2" 
                Content="{DynamicResource Common_CloseButton}" 
                Command="{Binding CloseCommand}" 
                IsDefault="True"
                IsCancel="True"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right"
                MinWidth="80"/>
    </Grid>
</Window>