<Window x:Class="FileCraft.Views.Shared.PresetDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FileCraft.ViewModels.Shared"
        xmlns:converters="clr-namespace:FileCraft.Shared.Converters"
        xmlns:icons="clr-namespace:Fonts"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="550" Width="800"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="BadgeButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{StaticResource BadgeBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="15,10"
                                Margin="0,0,10,0"
                                MinWidth="120"
                                Cursor="Hand">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BadgeHoverBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BadgePressedBackgroundBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BadgePressedBackgroundBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BadgeStaticBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BadgeInactiveBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>

        <DataTemplate x:Key="BadgeContentTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontFamily="{StaticResource MaterialIcons}" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInteractive}" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource GrayTextBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Value}" FontWeight="Bold" FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInteractive}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource GrayTextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{StaticResource GrayTextBrush}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Visibility="{Binding IsSummaryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding PresetName}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="{DynamicResource LastModifiedLabel}" Foreground="{StaticResource GrayTextBrush}" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding DisplayDateString}" FontWeight="SemiBold"/>
                </StackPanel>
                <TextBlock Text="{Binding Description}"
                           FontStyle="Italic"
                           Foreground="{StaticResource GrayTextBrush}"
                           Margin="0,5,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Visibility="{Binding IsContentDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Command="{Binding BackCommand}"
                        Style="{StaticResource BorderlessIconButton}"
                        ToolTip="{DynamicResource Details_Back}"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Width="32" Height="32">
                    <Viewbox>
                        <TextBlock Text="{x:Static icons:MaterialIcons.keyboard_arrow_left}" FontFamily="{StaticResource MaterialIcons}" Foreground="{StaticResource PrimaryBrush}"/>
                    </Viewbox>
                </Button>
                <TextBlock Text="{Binding DetailTitle}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Statistics}" Margin="0,0,0,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ContentControl>
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <Border Style="{StaticResource BadgeStaticBorderStyle}">
                                                <ContentPresenter ContentTemplate="{StaticResource BadgeContentTemplate}" Content="{Binding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInteractive}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <Button Command="{Binding Command}" Style="{StaticResource BadgeButtonStyle}">
                                                        <ContentPresenter ContentTemplate="{StaticResource BadgeContentTemplate}" Content="{Binding}"/>
                                                    </Button>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="2">
            <GroupBox Header="{Binding ContentHeader}" Visibility="{Binding IsSummaryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBox Text="{Binding SummaryText, Mode=OneWay}"
                         Style="{StaticResource ModernTextBoxStyle}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"/>
            </GroupBox>

            <GroupBox Visibility="{Binding IsContentDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <GroupBox.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DetailTitle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="{Binding ToggleViewButtonText}"
                                Command="{Binding ToggleViewModeCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Padding="8,2"
                                FontSize="11"
                                Height="24"
                                Margin="15,0,0,0"/>
                    </Grid>
                </GroupBox.Header>
                <TextBox Text="{Binding DetailText, Mode=OneWay}"
                         Style="{StaticResource ModernTextBoxStyle}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"/>
            </GroupBox>
        </Grid>

        <Button Grid.Row="3"
                Content="{DynamicResource Common_CloseButton}"
                Command="{Binding CloseCommand}"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Right"
                MinWidth="80"
                Margin="0,15,0,0"
                IsCancel="True"/>
    </Grid>
</Window>