<Window x:Class="FileCraft.Views.Shared.PresetDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:FileCraft.ViewModels.Shared"
        xmlns:converters="clr-namespace:FileCraft.Shared.Converters"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="500" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="{Binding PresetName}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Last Modified:" Foreground="{StaticResource GrayTextBrush}" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="{Binding Description}"
                       FontStyle="Italic"
                       Foreground="{StaticResource GrayTextBrush}"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding Description, Converter={StaticResource NullToVisibilityConverter}}"/>
        </StackPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Statistics}" Margin="0,0,0,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#F8F9FA" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="15,10" Margin="0,0,10,0" MinWidth="120">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontFamily="{StaticResource MaterialIcons}" FontSize="24" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Value}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{StaticResource GrayTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <GroupBox Grid.Row="2" Header="{Binding ContentHeader}">
            <ListBox ItemsSource="{Binding ContentList}"
                     BorderThickness="0"
                     Background="Transparent"
                     FontFamily="Consolas"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <Button Grid.Row="3"
                Content="{DynamicResource Common_CloseButton}"
                Command="{Binding CloseCommand}"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Right"
                MinWidth="80"
                Margin="0,15,0,0"
                IsCancel="True"/>
    </Grid>
</Window>