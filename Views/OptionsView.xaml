<UserControl x:Class="FileCraft.Views.OptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:FileCraft.ViewModels.Functional"
             xmlns:icons="clr-namespace:Fonts"
             xmlns:helpers="clr-namespace:FileCraft.Shared.Helpers"
             xmlns:controls="clr-namespace:FileCraft.Views.Shared.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:OptionsViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="UnlinkButtonStyle" TargetType="Button" BasedOn="{StaticResource BorderlessIconButton}">
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock x:Name="IconText"
                                   Text="{x:Static icons:MaterialIcons.link}"
                                   FontFamily="{StaticResource MaterialIcons}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="22"
                                   VerticalAlignment="Center"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock Text="{x:Static icons:MaterialIcons.link_off}"
                                           FontFamily="{StaticResource MaterialIcons}"
                                           Foreground="{StaticResource DangerBrush}"
                                           FontSize="22"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition>
                <RowDefinition.Style>
                    <Style TargetType="RowDefinition">
                        <Setter Property="Height" Value="Auto"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="Presets">
                                <Setter Property="Height" Value="0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="CopyTree">
                                <Setter Property="Height" Value="0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="IgnoredFolders">
                                <Setter Property="Height" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </RowDefinition.Style>
            </RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="3*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="Presets">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="CopyTree">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="IgnoredFolders">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="2*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="Presets">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="CopyTree">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="IgnoredFolders">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Margin="5" Padding="10">
                <GroupBox.Header>
                    <StackPanel Style="{StaticResource HeaderStackPanelStyle}">
                        <TextBlock Text="{DynamicResource ManagePresetsHeader}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <controls:FullscreenToggleButton Command="{Binding FullscreenManager.ToggleCommand}"
                                                         CurrentState="{Binding FullscreenManager.CurrentState}"
                                                         TargetState="{x:Static viewmodels:OptionsFullscreenState.Presets}"/>
                    </StackPanel>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <controls:PresetListControl Grid.Row="0" DataContext="{Binding PresetListViewModel}"/>

                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <Button Content="{DynamicResource OpenSaveFolderButton}"
                                Command="{Binding OpenSaveFolderCommand}"
                                Margin="0,0,0,5"
                                Style="{StaticResource WarningButton}"/>

                        <Button Content="{DynamicResource DeleteCurrentSaveButton}"
                                Command="{Binding DeleteCurrentSaveCommand}"
                                Margin="0,0,0,0"
                                Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition>
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="Auto"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="CopyTree">
                                        <Setter Property="Height" Value="*"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="IgnoredFolders">
                                        <Setter Property="Height" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>
                    <RowDefinition>
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="*"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="CopyTree">
                                        <Setter Property="Height" Value="0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FullscreenManager.CurrentState}" Value="IgnoredFolders">
                                        <Setter Property="Height" Value="*"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Margin="5" Padding="10">
                    <GroupBox.Header>
                        <StackPanel Style="{StaticResource HeaderStackPanelStyle}">
                            <TextBlock Text="{DynamicResource CopyFolderTreeContentHeader}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <controls:FullscreenToggleButton Command="{Binding FullscreenManager.ToggleCommand}"
                                                         CurrentState="{Binding FullscreenManager.CurrentState}"
                                                         TargetState="{x:Static viewmodels:OptionsFullscreenState.CopyTree}"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding ActiveLinkGroups}" Margin="0,0,0,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:LinkGroupViewModel}">
                                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8,5" Margin="0,2">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LinkedTabs[0].Icon}"
                                                       FontFamily="{StaticResource MaterialIcons}"
                                                       Foreground="{Binding LinkedTabs[0].IconBrush}"
                                                       FontSize="22" Margin="0,0,5,0" VerticalAlignment="Center"
                                                       ToolTip="{Binding LinkedTabs[0].Name}"/>

                                            <Button Style="{StaticResource UnlinkButtonStyle}"
                                                    ToolTip="{DynamicResource Options_UnlinkTooltip}"
                                                    Command="{Binding DataContext.UnlinkFolderTreeGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding GroupId}"
                                                    VerticalAlignment="Center"
                                                    Margin="5,0"/>

                                            <ItemsControl ItemsSource="{Binding RestOfTabs}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Icon}"
                                                                   FontFamily="{StaticResource MaterialIcons}"
                                                                   Foreground="{Binding IconBrush}"
                                                                   FontSize="22" Margin="0,0,5,0" VerticalAlignment="Center"
                                                                   ToolTip="{Binding Name}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{DynamicResource CopyFromTabLabel}" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding AllTabs}"
                                  SelectedItem="{Binding SelectedSourceTab}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="{StaticResource MaterialIcons}"
                                                   Foreground="{Binding IconBrush}"
                                                   FontSize="20" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Static icons:MaterialIcons.link}"
                                                   FontFamily="{StaticResource MaterialIcons}"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontSize="16" Margin="5,0,0,0" VerticalAlignment="Center"
                                                   ToolTip="Linked to other tabs"
                                                   Visibility="{Binding IsLinked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="{DynamicResource CopyToTabLabel}" Margin="0,10,0,2"/>
                        <ComboBox ItemsSource="{Binding AllTabs}"
                                  SelectedItem="{Binding SelectedDestinationTab}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="{StaticResource MaterialIcons}"
                                                   Foreground="{Binding IconBrush}"
                                                   FontSize="20" Margin="0,0,5,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Static icons:MaterialIcons.link}"
                                                   FontFamily="{StaticResource MaterialIcons}"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontSize="16" Margin="5,0,0,0" VerticalAlignment="Center"
                                                   ToolTip="Linked to other tabs"
                                                   Visibility="{Binding IsLinked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                            <Button Content="{DynamicResource CopyFolderTreeButton}"
                                Command="{Binding CopyFolderTreeCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,5,0"/>
                            <Button Content="{DynamicResource Options_LinkFolderTreesButton}"
                                Command="{Binding LinkFolderTreesCommand}"
                                Style="{StaticResource SuccessButton}"
                                HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Margin="5" Padding="10">
                    <GroupBox.Header>
                        <StackPanel Style="{StaticResource HeaderStackPanelStyle}">
                            <TextBlock Text="{DynamicResource IgnoreFoldersHeader}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <controls:FullscreenToggleButton Command="{Binding FullscreenManager.ToggleCommand}"
                                                         CurrentState="{Binding FullscreenManager.CurrentState}"
                                                         TargetState="{x:Static viewmodels:OptionsFullscreenState.IgnoredFolders}"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="{DynamicResource EditFoldersButton}" Command="{Binding EditIgnoredFoldersCommand}" Margin="0,0,5,0"/>
                        </StackPanel>

                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="{StaticResource TextBoxBackgroundBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                                <TextBlock Text="{Binding IgnoredFoldersText}" TextWrapping="Wrap" Foreground="{StaticResource GrayTextBrush}"/>
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </GroupBox>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontSize="12"
                   Foreground="{StaticResource GrayTextBrush}"
                   Margin="10">
            <Run Text="{DynamicResource Common_VersionLabel}"/>
            <Run Text="{Binding Version, Mode=OneWay}"/>
        </TextBlock>
    </Grid>
</UserControl>